# Polygon.io API key — get one at https://polygon.io
# Free tier = historical daily bars only. Stocks Starter ($29/mo) = real-time.
POLYGON_API_KEY=your_polygon_api_key_here

# Finnhub API key — get one FREE at https://finnhub.io (Dashboard → API Key, 30 sec signup)
# Free tier: 60 req/min, ~15 min delayed US stock quotes.
# Without this key: chart and price show previous session EOD close only.
# With this key: today's candle appears on the chart with live (~15 min delayed) price.
FINNHUB_API_KEY=your_finnhub_api_key_here

# Anthropic API key — get one at https://console.anthropic.com
# Used for the "Deep Analysis — Ask Claude" button on stock/crypto detail pages.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
